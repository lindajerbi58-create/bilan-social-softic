generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = "file:./dev.db"
}
model User {
  id          Int      @id @default(autoincrement())
  fullName    String
  email       String   @unique
  phone       String
  password    String
  role        String
  department  String
  poste       String
  createdAt   DateTime @default(now())
}